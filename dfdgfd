            local label = Instance.new("TextLabel")
            label.Text = title
            label.Font = Enum.Font.GothamBold
            label.TextSize = 14
            label.TextColor3 = Theme.TextPrimary
            label.Position = UDim2.new(0, 82, 0.5, 0)
            label.AnchorPoint = Vector2.new(0, 0.5)
            label.Size = UDim2.new(1, -205, 0, 40) -- Fixed overlap by increasing offset
            label.TextXAlignment = Enum.TextXAlignment.Left
            label.BackgroundTransparency = 1
            label.TextTruncate = Enum.TextTruncate.AtEnd
            label.Parent = frame
 
            local bindBtn = Instance.new("TextButton")
            bindBtn.Size = UDim2.new(0, 100, 0, 36)
            bindBtn.Position = UDim2.new(1, -12, 0.5, 0)
            bindBtn.AnchorPoint = Vector2.new(1, 0.5)
            bindBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
            bindBtn.Text = ""
            bindBtn.Parent = frame
            Corner(8, bindBtn)
            Stroke(Theme.Border, 1, bindBtn)
 
            local bindText = Instance.new("TextLabel")
            bindText.Size = UDim2.fromScale(1, 1)
            bindText.BackgroundTransparency = 1
            bindText.Text = currentBind.Name
            bindText.TextColor3 = Theme.TextPrimary
            bindText.Font = Enum.Font.GothamBold
            bindText.TextSize = 13
            bindText.Parent = bindBtn
 
            local lockControl;
            bindBtn.MouseButton1Click:Connect(function()
                if lockControl and lockControl:IsLocked() then return end
                binding = true
                bindText.Text = "..."
            end)
 
            UserInputService.InputBegan:Connect(function(input)
                if binding and input.UserInputType == Enum.UserInputType.Keyboard then
                    binding = false
                    currentBind = input.KeyCode
                    bindText.Text = currentBind.Name
                    callback(currentBind)
                end
            end)

            lockControl = ApplyLocking(frame)
            return lockControl
        end

        -- // NEW SKILL SELECTOR COMPONENT
        function Elements:AddSkillSelector(config)
            local title = config.Title or "Z"
            local side = config.Side
            local callback = config.Callback or function() end
            
            local isEnabled = config.DefaultEnabled or false
            local holdValue = config.DefaultHold or 0.5

            local frame = Instance.new("Frame")
            frame.Size = UDim2.new(1, 0, 0, 75)
            frame.BackgroundTransparency = 1
            frame.Parent = (side == "Right" and currentRightColumn) or currentLeftColumn
            
            -- Key Label (e.g., "Z")
            local keyLabel = Instance.new("TextLabel")
            keyLabel.Size = UDim2.new(0, 30, 1, 0)
            keyLabel.Position = UDim2.new(0, 5, 0, 0)
            keyLabel.BackgroundTransparency = 1
            keyLabel.Text = title
            keyLabel.TextColor3 = Theme.TextPrimary
            keyLabel.Font = Enum.Font.GothamBold
            keyLabel.TextSize = 18
            keyLabel.TextXAlignment = Enum.TextXAlignment.Left
            keyLabel.Parent = frame

            -- Toggle Container
            local toggleContainer = Instance.new("Frame")
            toggleContainer.Size = UDim2.new(0, 60, 0, 30)
            toggleContainer.Position = UDim2.new(0, 55, 0.5, -10)
            toggleContainer.BackgroundColor3 = Color3.fromRGB(35, 35, 38)
            toggleContainer.Parent = frame
            Corner(4, toggleContainer)
            
            local toggleKnob = Instance.new("Frame")
            toggleKnob.Size = UDim2.new(0, 22, 0, 22)
            toggleKnob.Position = isEnabled and UDim2.new(1, -26, 0.5, 0) or UDim2.new(0, 4, 0.5, 0)
            toggleKnob.AnchorPoint = Vector2.new(0, 0.5)
            toggleKnob.BackgroundColor3 = isEnabled and Theme.NeonGreen or Color3.fromRGB(80, 80, 85)
            toggleKnob.Parent = toggleContainer
            Corner(4, toggleKnob)

            local toggleBtn = Instance.new("TextButton")
            toggleBtn.Size = UDim2.fromScale(1, 1)
            toggleBtn.BackgroundTransparency = 1
            toggleBtn.Text = ""
            toggleBtn.Parent = toggleContainer

            local enabledLabel = Instance.new("TextLabel")
            enabledLabel.Size = UDim2.new(1, 0, 0, 15)
            enabledLabel.Position = UDim2.new(0, 0, 1, 5)
            enabledLabel.BackgroundTransparency = 1
            enabledLabel.Text = "Enabled"
            enabledLabel.TextColor3 = Theme.TextSec
            enabledLabel.Font = Enum.Font.GothamMedium
            enabledLabel.TextSize = 11
            enabledLabel.Parent = toggleContainer

            -- Hold Section
            local holdLabel = Instance.new("TextLabel")
            holdLabel.Size = UDim2.new(0, 40, 0, 20)
            holdLabel.Position = UDim2.new(1, -105, 0.5, -10)
            holdLabel.BackgroundTransparency = 1
            holdLabel.Text = "hold"
            holdLabel.TextColor3 = Theme.TextPrimary
            holdLabel.Font = Enum.Font.GothamBold
            holdLabel.TextSize = 14
            holdLabel.TextXAlignment = Enum.TextXAlignment.Right
            holdLabel.Parent = frame

            local holdInputFrame = Instance.new("Frame")
            holdInputFrame.Size = UDim2.new(0, 55, 0, 32)
            holdInputFrame.Position = UDim2.new(1, -5, 0.5, -10)
            holdInputFrame.AnchorPoint = Vector2.new(1, 0)
            holdInputFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 28)
            holdInputFrame.Parent = frame
            Corner(6, holdInputFrame)
            Stroke(Theme.Border, 1, holdInputFrame)

            local holdInput = Instance.new("TextBox")
            holdInput.Size = UDim2.fromScale(1, 1)
            holdInput.BackgroundTransparency = 1
            holdInput.Text = tostring(holdValue)
            holdInput.TextColor3 = Theme.TextPrimary
            holdInput.Font = Enum.Font.GothamBold
            holdInput.TextSize = 13
            holdInput.ClearTextOnFocus = false
            holdInput.Parent = holdInputFrame

            -- Logic
            local function update()
                TweenService:Create(toggleKnob, TweenInfo.new(0.2), {
                    Position = isEnabled and UDim2.new(1, -26, 0.5, 0) or UDim2.new(0, 4, 0.5, 0),
                    BackgroundColor3 = isEnabled and Theme.NeonGreen or Color3.fromRGB(80, 80, 85)
                }):Play()
                callback({Enabled = isEnabled, Hold = holdValue})
            end

            toggleBtn.MouseButton1Click:Connect(function()
                isEnabled = not isEnabled
                update()
            end)

            holdInput.FocusLost:Connect(function()
                local val = tonumber(holdInput.Text)
                if val then
                    holdValue = val
                else
                    holdInput.Text = tostring(holdValue)
                end
                update()
            end)

            local lockControl = ApplyLocking(frame)
            
            function lockControl:SetValue(config)
                if config.Enabled ~= nil then isEnabled = config.Enabled end
                if config.Hold ~= nil then 
                    holdValue = config.Hold 
                    holdInput.Text = tostring(holdValue)
                end
                update()
            end

            return lockControl
        end
 
    return Elements
    end
    return Window
end
 
return AstralLib
