                if currentModel then currentModel:Destroy() end
                
                local target = modelSource()
 
                if target then
                    currentModel = target:Clone()
                    currentModel.Parent = Viewport
                    local cf, size = currentModel:GetBoundingBox()
                    zoomDist = size.Magnitude * 1.5
                    UpdateCamera()
                end
            end
 
